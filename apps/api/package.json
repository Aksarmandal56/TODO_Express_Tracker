    "reflect-metadata": "^0.2.2",
    "bull": "^4.12.9",
    "stripe": "^15.8.0",
    "@anthropic-ai/sdk": "^0.21.1",
    "pdf-parse": "^1.1.1",
    "multer": "^2.1.1",
