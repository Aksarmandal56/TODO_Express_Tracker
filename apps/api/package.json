    "@nestjs/websockets": "^10.3.8",
    "@nestjs/mongoose": "^10.0.6",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/config": "^3.2.2",
    "@nestjs/schedule": "^4.0.2",
    "@nestjs/bull": "^10.1.1",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^5.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "mongoose": "^8.3.4",
    "bcryptjs": "^2.4.3",
